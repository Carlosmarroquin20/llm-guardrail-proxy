# Sample environment configuration. Copy to ``.env`` and adjust as needed.
#
# Settings are nested by concern. The double-underscore separator is the
# pydantic-settings convention for nested fields:
#
#     GUARDRAIL_<group>__<field>=<value>
#
# Every key shown below is optional; defaults live in
# ``src/llm_guardrail_proxy/proxy/settings.py``.

# --- Network -----------------------------------------------------------
GUARDRAIL_NETWORK__LISTEN_HOST=127.0.0.1
GUARDRAIL_NETWORK__LISTEN_PORT=8080
GUARDRAIL_NETWORK__OPENAI_BASE_URL=https://api.openai.com
GUARDRAIL_NETWORK__ANTHROPIC_BASE_URL=https://api.anthropic.com
GUARDRAIL_NETWORK__UPSTREAM_TIMEOUT_SECONDS=30

# --- Circuit breaker --------------------------------------------------
GUARDRAIL_BREAKER__FAILURE_THRESHOLD=5
GUARDRAIL_BREAKER__RESET_SECONDS=30

# --- Tokenomics policy ------------------------------------------------
GUARDRAIL_TOKENOMICS__MAX_PROMPT_TOKENS=8000
GUARDRAIL_TOKENOMICS__MAX_PROMPT_COST_USD=0.05
GUARDRAIL_TOKENOMICS__ALLOW_UNKNOWN_MODELS=true

# --- Content guardrails (Phase 3) -------------------------------------
GUARDRAIL_SCANNING__ENABLE_SECRETS=true
# PII requires the [pii] extra and a spaCy model.
GUARDRAIL_SCANNING__ENABLE_PII=false
# Either "block" (Reject 403) or "redact" (rewrite prompt before forward).
GUARDRAIL_SCANNING__PII_POLICY=block
GUARDRAIL_SCANNING__PII_SCORE_THRESHOLD=0.5

# --- FinOps audit plane (Phase 4) -------------------------------------
GUARDRAIL_AUDIT__ENABLED=true
GUARDRAIL_AUDIT__MEMORY_CAPACITY=1000
# Optional persistent sinks — leave commented to keep audit in-memory.
# GUARDRAIL_AUDIT__JSONL_PATH=./var/audit.jsonl
# GUARDRAIL_AUDIT__DUCKDB_PATH=./var/audit.duckdb
# Whether a LoggingAuditSink is part of the composite.
GUARDRAIL_AUDIT__LOG_ENABLED=true

# --- Stats endpoint (Phase 4c) ----------------------------------------
GUARDRAIL_STATS__ENABLE_ENDPOINT=true
GUARDRAIL_STATS__ENABLE_DASHBOARD=true

# --- Structlog stack --------------------------------------------------
# "json" (production) or "console" (interactive dev).
GUARDRAIL_LOGGING__FORMAT=json
GUARDRAIL_LOGGING__LEVEL=INFO
