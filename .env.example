# Sample environment configuration. Copy to ``.env`` and adjust as needed.
# Every key shown below is optional; defaults are documented in
# ``src/llm_guardrail_proxy/proxy/settings.py``.

# --- Upstream targets -------------------------------------------------
GUARDRAIL_OPENAI_BASE_URL=https://api.openai.com
GUARDRAIL_ANTHROPIC_BASE_URL=https://api.anthropic.com

# --- Network behaviour ------------------------------------------------
GUARDRAIL_LISTEN_HOST=127.0.0.1
GUARDRAIL_LISTEN_PORT=8080
GUARDRAIL_UPSTREAM_TIMEOUT_SECONDS=30

# --- Circuit breaker --------------------------------------------------
GUARDRAIL_BREAKER_FAILURE_THRESHOLD=5
GUARDRAIL_BREAKER_RESET_SECONDS=30

# --- Tokenomics policy ------------------------------------------------
GUARDRAIL_MAX_PROMPT_TOKENS=8000
GUARDRAIL_MAX_PROMPT_COST_USD=0.05
GUARDRAIL_ALLOW_UNKNOWN_MODELS=true

# --- Content guardrails (Phase 3) -------------------------------------
GUARDRAIL_ENABLE_SECRET_SCANNING=true

# PII detection requires the [pii] extra and a spaCy model. Leaving this
# false skips loading Presidio entirely.
GUARDRAIL_ENABLE_PII_SCANNING=false
# Either "block" (Reject 403) or "redact" (rewrite the prompt before forward).
GUARDRAIL_PII_POLICY=block
GUARDRAIL_PII_SCORE_THRESHOLD=0.5
